{
  "name": "consulta-reemplacamiento-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "local": "ng serve --port 4500 --configuration local",
    "desa": "ng serve --port 4500 --configuration development",
    "prod": "ng serve --port 4500 --configuration production",
    "build": "ng build --base-href /consulta-reemplacamiento-ui/",
    "build:desa": "ng build --base-href /consulta-reemplacamiento-ui/ --configuration development",
    "build:prod": "ng build --base-href /consulta-reemplacamiento-ui/ --configuration production --output-path=dist/consulta-reemplacamiento-ui",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "public": "ng serve --host 0.0.0.0 --port 4600 --configuration development",
    "generate-api": "npx openapi-generator-cli generate -i openapi.json -g typescript-angular -o src/app/api",
    "regenerate-api": "rimraf src/app/api && yarn generate-api"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.18",
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/forms": "^20.3.18",
    "@angular/platform-browser": "^20.3.18",
    "@angular/platform-browser-dynamic": "^20.3.18",
    "@angular/router": "^20.3.18",
    "@fortawesome/fontawesome-free": "^7.0.0",
    "ng-zorro-antd": "^20.4.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.18",
    "@angular/cli": "^20.3.18",
    "@angular/compiler-cli": "^20.3.18",
    "@openapitools/openapi-generator-cli": "^2.30.2",
    "@types/jasmine": "~5.1.0",
    "autoprefixer": "^10.4.20",
    "jasmine-core": "~5.8.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2"
  }
}
